{
  "name": "api-control-payment",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "build": "rm -rf build/ && tsc",
    "dev": "cp .env.development .env && nodemon -r tsconfig-paths/register src/index.ts",
    "dev:cloud": "cp .env.production .env && nodemon -r tsconfig-paths/register src/index.ts",
    "start": "node build/src/index.js",
    "start:local": "cp .env.development .env && node build/src/index.js",
    "start:cloud": "cp .env.production .env && node build/src/index.js",
    "prepare": "husky",
    "file-migraton": "npx sequelize-cli migration:generate --name [file-name]",
    "file-generate": "npx sequelize-cli seed:generate --name [file-name]",
    "seed:all": "npx sequelize-cli db:seed:all",
    "migration": "npx sequelize-cli db:migrate",
    "undo-m": "npx sequelize-cli db:migrate:undo",
    "undo-all-m": "npx sequelize-cli db:migrate:all",
    "lint": "eslint src/**/*.ts",
    "docker": "docker compose up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "awilix": "^12.0.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "nodemailer": "^6.9.16",
    "sequelize": "^6.37.3",
    "tedious": "^18.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@eslint/js": "^9.9.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/dotenv": "^8.2.0",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.1",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  },
